@model List<DentalClinicWebsite.Models.Appointment>

@{
    ViewData["Title"] = "Admin Bookings";
}

<style>
    .admin-page {
        background: linear-gradient(135deg, #f8fbff 0%, #eef5ff 100%);
        min-height: 100vh;
        padding: 40px 0;
    }

    .admin-card {
        background: #ffffff;
        border: 1px solid #dbeafe;
        border-radius: 18px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        overflow: hidden;
    }

    .admin-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0b3d91 100%);
        color: white;
        padding: 24px 30px;
    }

        .admin-header h2 {
            margin: 0;
            font-weight: 700;
        }

        .admin-header p {
            margin: 6px 0 0;
            opacity: 0.9;
        }

    .table-wrap {
        padding: 25px;
    }

    .custom-table {
        margin-bottom: 0;
        border-radius: 12px;
        overflow: hidden;
    }

        .custom-table thead {
            background: #0b3d91;
            color: #ffffff;
        }

        .custom-table th {
            border: none !important;
            font-size: 14px;
            padding: 14px 12px;
            vertical-align: middle;
            white-space: nowrap;
        }

        .custom-table td {
            vertical-align: middle;
            padding: 14px 12px;
            border-color: #e5e7eb;
            color: #111827;
            background: #ffffff;
        }

        .custom-table tbody tr:hover td {
            background: #f1f7ff;
            transition: 0.2s ease-in-out;
        }

    .booking-id {
        font-weight: 700;
        color: #0d6efd;
    }

    .service-badge {
        background: #e7f1ff;
        color: #0b3d91;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        display: inline-block;
    }

    .message-box {
        max-width: 220px;
        white-space: normal;
        color: #374151;
    }

    .btn-edit-custom {
        background: #0d6efd;
        border: none;
        color: #fff;
        border-radius: 8px;
        padding: 6px 14px;
        font-weight: 600;
    }

        .btn-edit-custom:hover {
            background: #0b5ed7;
            color: #fff;
        }

    .btn-delete-custom {
        background: #111827;
        border: none;
        color: #fff;
        border-radius: 8px;
        padding: 6px 14px;
        font-weight: 600;
    }

        .btn-delete-custom:hover {
            background: #000000;
            color: #fff;
        }

    .empty-state {
        padding: 30px;
        text-align: center;
        color: #6b7280;
        font-weight: 500;
    }

    .alert-success {
        border-radius: 10px;
        border: none;
        background: #e8f5e9;
        color: #1b5e20;
        font-weight: 600;
    }
</style>



<div class="admin-page">
    <div class="container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success mb-4">
                @TempData["Success"]
            </div>
        }

        <div class="admin-card">
            <div class="admin-header">
                <h2>Manage Bookings</h2>
                <p>View, edit, and delete patient appointment records.</p>
            </div>

            <div class="table-wrap">
                <div class="table-responsive">
                    <table class="table custom-table align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Full Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Service</th>
                                <th>Preferred Date</th>
                                <th>Preferred Time</th>
                                <th>Message</th>
                                <th>Created At</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td><span class="booking-id">#@item.Id</span></td>
                                        <td>@item.FullName</td>
                                        <td>@item.Email</td>
                                        <td>@item.Phone</td>
                                        <td>
                                            <span class="service-badge">@item.Service</span>
                                        </td>
                                        <td>@item.PreferredDate</td>
                                        <td>@item.PreferredTime</td>
                                        <td>
                                            <div class="message-box">
                                                @item.Message
                                            </div>
                                        </td>
                                        <td>@item.CreatedAt</td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-action="Edit"
                                                       asp-route-id="@item.Id"
                                                       class="btn btn-edit-custom btn-sm">
                                                    Edit
                                                </a>

                                                <form asp-action="Delete"
                                                      asp-route-id="@item.Id"
                                                      method="post"
                                                      style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit"
                                                            class="btn btn-delete-custom btn-sm"
                                                            onclick="return confirm('Are you sure you want to delete this booking?');">
                                                        Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="empty-state">
                                        No bookings found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>