@model DentalClinicWebsite.Models.Appointment
@{
    ViewData["Title"] = "Home";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center mt-3">
        @TempData["Success"]?.ToString()
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mt-3">
        @TempData["Error"]?.ToString()
    </div>
}

<section id="hero" class="hero-section text-center text-md-start section-animate">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4">Your Smile, Our Priority</h1>
                <p class="lead">Professional dental care for you and your family.</p>
                <a href="#" class="btn btn-primary btn-lg mt-3" data-bs-toggle="modal" data-bs-target="#appointmentModal">
                    Book Appointment
                </a>
            </div>
            <div class="col-md-6">
                <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/doctor.png?sp=r&st=2026-03-18T09:38:04Z&se=2026-04-08T17:53:04Z&spr=https&sv=2024-11-04&sr=b&sig=qdEAv1E4WGtMnzpDyPaklppTZYnmvanawwaME51ISu4%3D" class="img-fluid rounded" alt="Dentist">
            </div>
        </div>
    </div>
</section>

<section id="services" class="services-section text-center py-5 section-animate">
    <div class="container">
        <h2 class="mb-5">Our Services</h2>
        <div class="row">
            <div class="col-md-4 mb-4">
