@model DentalClinicWebsite.Models.Appointment
@{
    ViewData["Title"] = "Home";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success text-center mt-3">
        @TempData["Success"]?.ToString()
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger text-center mt-3">
        @TempData["Error"]?.ToString()
    </div>
}

<section id="hero" class="hero-section text-center text-md-start">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="display-4">Your Smile, Our Priority</h1>
                <p class="lead">Professional dental care for you and your family.</p>
                <a href="#" class="btn btn-primary btn-lg mt-3" data-bs-toggle="modal" data-bs-target="#appointmentModal">
                    Book Appointment
                </a>
            </div>
            <div class="col-md-6">
                <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/doctor.png?sp=r&st=2026-03-12T04:13:26Z&se=2026-03-12T12:28:26Z&spr=https&sv=2024-11-04&sr=b&sig=GcP9VNJdND7bPy1zwWh6%2BaQDT44K23lHcNHsDsXcPwc%3D" class="img-fluid rounded" alt="Dentist">
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="services-section text-center py-5">
        <div class="container">
            <h2 class="mb-5">Our Services</h2>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card service-card h-100 shadow-sm">
                    <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/General.png?sp=r&st=2026-03-12T04:14:57Z&se=2026-04-02T12:29:57Z&spr=https&sv=2024-11-04&sr=b&sig=mB691OBj6wgKBVpipw8eAv7tzGRjk4GMj4M4zYTXILA%3D" class="card-img-top" alt="General Dentistry">
                            <div class="card-body">
                                <i class="bi bi-person-check-fill fs-1 mb-3 text-primary"></i>
                                <h5 class="card-title">General Dentistry</h5>
                                <p class="card-text">Routine dental exams, cleanings, and preventive care.</p>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4 mb-4">
                        <div class="card service-card h-100 shadow-sm">
                    <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/Cosmetic.png?sp=r&st=2026-03-12T04:15:38Z&se=2026-04-02T12:30:38Z&spr=https&sv=2024-11-04&sr=b&sig=N7gtLvVoCPl%2FkUIsKCJ5q9MW838gWC8RjFcGlzW9ZH0%3D" class="card-img-top" alt="Cosmetic Dentistry">
                                <div class="card-body">
                                    <i class="bi bi-star-fill fs-1 mb-3 text-primary"></i>
                                    <h5 class="card-title">Cosmetic Dentistry</h5>
                                    <p class="card-text">Teeth whitening, veneers, and smile makeovers.</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4 mb-4">
                            <div class="card service-card h-100 shadow-sm">
                    <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/Orthodontics.png?sp=r&st=2026-03-12T04:16:12Z&se=2026-04-02T12:31:12Z&spr=https&sv=2024-11-04&sr=b&sig=ToviRdclW3jQlB9T%2BBuNlzfKoETu0BBCjna6cmg7P7w%3D" class="card-img-top" alt="Orthodontics">
                                    <div class="card-body">
                                        <i class="bi bi-check2-square fs-1 mb-3 text-primary"></i>
                                        <h5 class="card-title">Orthodontics</h5>
                                        <p class="card-text">Braces, Invisalign, and bite alignment treatments.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="about" class="about-section py-5 bg-light">
                    <div class="container">
                        <h2 class="mb-4 text-center">About Us</h2>
                        <div class="row align-items-center">
                            <div class="col-md-6">
                <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/teeth.png?sp=r&st=2026-03-12T04:16:37Z&se=2026-04-02T12:31:37Z&spr=https&sv=2024-11-04&sr=b&sig=lDwqu8rEl81xXeV33OaN9m48Ss5925sLCIOG%2FEZlSeE%3D" class="img-fluid rounded" alt="Clinic">
                                </div>
                                <div class="col-md-6">
                                    <p>SmileCare Dental is committed to providing the highest quality dental care in a friendly and comfortable environment. Our experienced team ensures every patient leaves with a bright and healthy smile.</p>
                                    <p>We use the latest technology and follow best practices to make sure your dental visit is safe, comfortable, and effective.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section id="contact" class="contact-section py-5">
                        <div class="container">
                            <h2 class="mb-4 text-center">Contact Us</h2>
                            <div class="row justify-content-center">
                                <div class="col-md-6">
                                    <form>
                                        <div class="mb-3">
                                            <label for="name" class="form-label">Name</label>
                                            <input type="text" class="form-control" id="name" placeholder="Your Name">
                                        </div>
                                        <div class="mb-3">
                                            <label for="email" class="form-label">Email</label>
                                            <input type="email" class="form-control" id="email" placeholder="you@example.com">
                                        </div>
                                        <div class="mb-3">
                                            <label for="message" class="form-label">Message</label>
                                            <textarea class="form-control" id="message" rows="4" placeholder="Your message"></textarea>
                                        </div>
                                        <button type="submit" class="btn btn-primary w-100">Send Message</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Appointment Modal -->
                    <div class="modal fade" id="appointmentModal" tabindex="-1" aria-labelledby="appointmentModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="appointmentModalLabel">Book Appointment</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>

                                <div class="modal-body">
                                    <form asp-action="Appointment" method="post">
                                        @Html.AntiForgeryToken()

                                        <div class="mb-3">
                                            <label asp-for="FullName" class="form-label"></label>
                                            <input asp-for="FullName" class="form-control" placeholder="Your full name" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Email" class="form-label"></label>
                                            <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Phone" class="form-label"></label>
                                            <input asp-for="Phone" class="form-control" placeholder="09xxxxxxxxx" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Service" class="form-label"></label>
                                            <select asp-for="Service" class="form-select">
                                                <option value="">Choose a service</option>
                                                <option value="General Dentistry">General Dentistry</option>
                                                <option value="Cosmetic Dentistry">Cosmetic Dentistry</option>
                                                <option value="Orthodontics">Orthodontics</option>
                                                <option value="Other">Other</option>
                                            </select>
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="PreferredDate" class="form-label"></label>
                                            <input asp-for="PreferredDate" type="date" class="form-control" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="PreferredTime" class="form-label"></label>
                                            <input asp-for="PreferredTime" type="time" class="form-control" />
                                        </div>

                                        <div class="mb-3">
                                            <label asp-for="Message" class="form-label"></label>
                                            <textarea asp-for="Message" class="form-control" rows="3" placeholder="Any specific concerns or requests"></textarea>
                                        </div>

                                        <button type="submit" class="btn btn-primary w-100">Book Appointment</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>