                    <div class="card-body">
                        <i class="bi bi-person-check-fill fs-1 mb-3 text-primary"></i>
                        <h5 class="card-title">General Dentistry</h5>
                        <p class="card-text">Routine dental exams, cleanings, and preventive care.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card service-card h-100 shadow-sm">
                    <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/Cosmetic.png?sp=r&st=2026-03-12T04:15:38Z&se=2026-04-02T12:30:38Z&spr=https&sv=2024-11-04&sr=b&sig=N7gtLvVoCPl%2FkUIsKCJ5q9MW838gWC8RjFcGlzW9ZH0%3D" class="card-img-top" alt="Cosmetic Dentistry">
                    <div class="card-body">
                        <i class="bi bi-star-fill fs-1 mb-3 text-primary"></i>
                        <h5 class="card-title">Cosmetic Dentistry</h5>
                        <p class="card-text">Teeth whitening, veneers, and smile makeovers.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card service-card h-100 shadow-sm">
                    <img src="https://dentalwebstorage001.blob.core.windows.net/dentalphoto/Orthodontics.png?sp=r&st=2026-03-12T04:16:12Z&se=2026-04-02T12:31:12Z&spr=https&sv=2024-11-04&sr=b&sig=ToviRdclW3jQlB9T%2BBuNlzfKoETu0BBCjna6cmg7P7w%3D" class="card-img-top" alt="Orthodontics">
                    <div class="card-body">
                        <i class="bi bi-check2-square fs-1 mb-3 text-primary"></i>
                        <h5 class="card-title">Orthodontics</h5>
                        <p class="card-text">Braces, Invisalign, and bite alignment treatments.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

